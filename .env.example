# API
PORT=3001
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin12345678
JWT_SECRET=change-me-in-production
DB_PATH=./data/explore.db

# Mailpit (local) — production: use Resend, SendGrid, Amazon SES, etc.
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=Explore <noreply@exploreapphq.com>

APP_URL=http://localhost:5173
SITE_URL=https://sunny-dolphin-b73804.netlify.app
VITE_SITE_URL=https://sunny-dolphin-b73804.netlify.app

# Frontend (Netlify build) — only if API is NOT proxied via netlify.toml
# VITE_API_URL=https://your-api.up.railway.app

# Firebase (Auth for team + Firestore waitlist)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Comma-separated emails allowed to use /team login
VITE_ADMIN_EMAILS=admin@example.com,you@yourdomain.com

# Supabase (Explore production moderation)
VITE_SUPABASE_URL=https://ookbeuiavzjhvezvamfu.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=replace-with-production-publishable-key
# Server-side only. Never prefix this with VITE_ and never expose it in browser code.
SUPABASE_SECRET_KEY=replace-with-production-service-role-key
# Optional temporary admin fallback until admin_users is populated.
EXPLORE_ADMIN_ALLOWED_EMAILS=you@exploreapphq.com

APP_STORE_URL=https://apps.apple.com/do/app/explore-tourism/id6748882805?l=en-GB
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.explore.miapp&hl=es
