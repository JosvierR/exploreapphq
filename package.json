{
  "name": "explore-atlas-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch --env-file=.env server/index.ts",
    "dev:all": "concurrently -n web,api -c blue,green \"npm run dev\" \"npm run dev:api\"",
    "build": "tsc -b && vite build",
    "build:api": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "lint": "tsc -b --noEmit",
    "test": "tsx src/lib/analyticsDisplay.test.ts && node server/api-lib/analytics/analyticsRouter.source.test.mjs && node server/api-lib/analytics/analyticsAdminApi.test.mjs && node server/api-lib/analytics/analyticsOperationsService.test.mjs && node server/api-lib/analytics/businessInsightsService.test.mjs",
    "obs:up": "docker compose -f observability/docker-compose.observability.yml up -d",
    "obs:down": "docker compose -f observability/docker-compose.observability.yml down",
    "obs:logs": "docker compose -f observability/docker-compose.observability.yml logs -f grafana prometheus loki",
    "obs:ps": "docker compose -f observability/docker-compose.observability.yml ps",
    "obs:smoke": "node scripts/obs-smoke.mjs",
    "obs:ready": "npm run obs:up && node scripts/obs-smoke.mjs --wait",
    "waitlist:notify": "tsx server/scripts/notify-launch.ts",
    "waitlist:notify:dry": "tsx server/scripts/notify-launch.ts -- --dry-run",
    "email:test": "tsx server/scripts/send-test-email.ts",
    "email:launch:test": "tsx server/scripts/send-launch-test-email.ts",
    "dev:mail": "docker compose up -d mailpit",
    "netlify:env": "powershell -ExecutionPolicy Bypass -File scripts/crear-netlify-env.ps1",
    "resend:check": "node scripts/check-resend-domain.mjs",
    "admin:provision": "node scripts/provision-supabase-admins.mjs",
    "admin:bootstrap": "node scripts/run-board-admin-bootstrap.mjs",
    "vercel:env": "powershell -ExecutionPolicy Bypass -File scripts/crear-vercel-env.ps1"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@netlify/blobs": "^8.1.0",
    "@supabase/supabase-js": "^2.108.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^2.2.13",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.0.0",
    "jsonwebtoken": "^9.0.2",
    "motion": "^12.42.2",
    "nodemailer": "^6.9.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "react-use-measure": "^2.1.7",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "vite": "^6.0.5"
  }
}
