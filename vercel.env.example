# Plantilla Vercel — Import .env en el deploy (Environment Variables → Import)
# Copia a vercel.env, rellena, y sube en Vercel. NO commitear vercel.env.

# --- Sitio (actualiza tras el primer deploy) ---
SITE_URL=https://www.exploreapphq.com
VITE_SITE_URL=https://www.exploreapphq.com
VITE_EXPLORE_WEB_URL=https://www.exploreapphq.com

# --- Firebase (web /team + waitlist) — proyecto turismo-oculto ---
VITE_FIREBASE_API_KEY=PEGA_AQUI
VITE_FIREBASE_AUTH_DOMAIN=turismo-oculto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=turismo-oculto
VITE_FIREBASE_STORAGE_BUCKET=turismo-oculto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=PEGA_AQUI
VITE_FIREBASE_APP_ID=PEGA_AQUI
VITE_ADMIN_EMAILS=josvierrod@exploreapphq.com

# --- Resend (emails) — dominio exploreapphq.com VERIFIED ---
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=PEGA_TU_API_KEY_RESEND_re_
SMTP_FROM=Explore <onboarding@exploreapphq.com>

# --- Twilio (SMS waitlist) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=PEGA_TWILIO_AUTH_TOKEN
TWILIO_FROM=+1xxxxxxxxxx

# --- Tiendas ---
APP_STORE_URL=https://apps.apple.com/do/app/explore-tourism/id6748882805?l=en-GB
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.explore.miapp&hl=es

# --- Admin API (hardcoded login uses ADMIN_PASSWORD) ---
ADMIN_PASSWORD=Admin

# --- Firebase Admin (serverless API) — una línea JSON, Sensitive ---
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...una linea...}

# --- Supabase production moderation ---
VITE_SUPABASE_URL=https://ookbeuiavzjhvezvamfu.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=PEGA_TU_PRODUCTION_PUBLISHABLE_KEY
# Sensitive. Server-side only. Do not create any VITE_ variable with this value.
SUPABASE_SECRET_KEY=PEGA_TU_PRODUCTION_SERVICE_ROLE_KEY
# Optional fallback until admin_users has your Supabase user id.
EXPLORE_ADMIN_ALLOWED_EMAILS=josvierrod@exploreapphq.com

# One-time bootstrap for directiva admin accounts (remove after use).
# ADMIN_BOOTSTRAP_SECRET=generate-a-long-random-secret

# --- Observability (Production — Sensitive where noted) ---
# Required for Grafana Cloud Loki + live /api/metrics scrapes.
APP_ENV=production
APP_VERSION=vercel-git-sha-or-release
METRICS_TOKEN=PEGA_UN_TOKEN_LARGO_SI_USAS_/api/metrics
GRAFANA_LOGS_ENABLED=true
# warn = warn+error to Loki (recommended). Use info for full request traces.
GRAFANA_LOGS_LEVEL=warn
GRAFANA_LOKI_URL=https://logs-prod-us-central1.grafana.net/loki/api/v1/push
GRAFANA_LOKI_USERNAME=PEGA_TU_INSTANCE_ID
GRAFANA_LOKI_TOKEN=PEGA_TU_GRAFANA_LOKI_TOKEN
