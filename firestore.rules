rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isTeamAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          "admin@example.com",
          "josvierrod@exploreapphq.com",
        ];
    }

    match /waitlist/{id} {
      allow read: if isTeamAdmin();

      allow create: if request.resource.data.keys().hasOnly(
            ['phone', 'email', 'createdAt', 'source', 'consentSms', 'seqStep']
          )
        && request.resource.data.phone is string
        && request.resource.data.phone.size() >= 8
        && request.resource.data.createdAt == request.time;

      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['email'])
        && request.resource.data.email is string;

      allow update: if isTeamAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
            ['launchNotifiedAt', 'seqStep', 'lastSeqAt', 'unsubscribed', 'email']
          );

      allow delete: if false;
    }

    match /feedback/{id} {
      allow read: if isTeamAdmin();
      allow create, update, delete: if false;
    }
  }
}
