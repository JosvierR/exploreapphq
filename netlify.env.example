# Copia a netlify.env, rellena PEGA_AQUI, importa en Netlify. NO subas netlify.env a Git.

VITE_FIREBASE_API_KEY=PEGA_AQUI
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=PEGA_AQUI
VITE_FIREBASE_APP_ID=PEGA_AQUI

VITE_ADMIN_EMAILS=tu-email@ejemplo.com

SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=PEGA_TU_API_KEY_RESEND
# Prueba: onboarding@resend.dev solo entrega al email de TU cuenta Resend
# Produccion: verifica exploreapphq.com en resend.com/domains y usa:
# SMTP_FROM=Explore <onboarding@exploreapphq.com>
SMTP_FROM=Explore <onboarding@exploreapphq.com>

SITE_URL=https://sunny-dolphin-b73804.netlify.app
VITE_SITE_URL=https://sunny-dolphin-b73804.netlify.app

# Feedback board (Canny / UserJot public board URL). Embeds at /feedback.
VITE_FEEDBACK_URL=

# SMS via Twilio (optional). Leave empty until you create the account + A2P 10DLC.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_MESSAGING_SERVICE_SID=

APP_STORE_URL=https://apps.apple.com/app/id0000000000
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.example.app

# Admin /admin/waitlist — Firebase service account JSON (una linea, Secret en Netlify)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
