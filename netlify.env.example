# Copia a netlify.env, rellena PEGA_AQUI, importa en Netlify. NO subas netlify.env a Git.

VITE_FIREBASE_API_KEY=PEGA_AQUI
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=PEGA_AQUI
VITE_FIREBASE_APP_ID=PEGA_AQUI

VITE_ADMIN_EMAILS=tu-email@ejemplo.com

SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=PEGA_TU_API_KEY_RESEND
SMTP_FROM=Explore <onboarding@resend.dev>

SITE_URL=https://tu-sitio.netlify.app

APP_STORE_URL=https://apps.apple.com/app/id0000000000
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.example.app
