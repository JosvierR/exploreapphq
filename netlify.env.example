# =============================================================================
# EXPLORE — Variables para NETLIFY
# =============================================================================
#
# PASOS (5 minutos):
#
# 1. Copia este archivo y renómbralo a:  netlify.env
#    (en la raíz del proyecto, junto a package.json)
#
# 2. Sustituye cada PEGA_AQUI con tus valores reales (Firebase + Resend).
#
# 3. En Netlify abre tu sitio → Site configuration → Environment variables
#
# 4. Clic en "Import from .env" (o "Add from file") y selecciona: netlify.env
#
# 5. Marca TODAS las variables con scope: "All" o al menos "Builds" + "Functions"
#
# 6. Deploys → Trigger deploy → Deploy site
#
# NO subas netlify.env a GitHub (contiene secretos).
#
# =============================================================================

# --- FIREBASE (obligatorio para /access y /team) ---
# Firebase Console → Project settings → Your apps → Web app → SDK setup
VITE_FIREBASE_API_KEY=PEGA_AQUI
# Proyecto existente: EXPLORE (turismo-oculto) en Firebase Console
VITE_FIREBASE_AUTH_DOMAIN=turismo-oculto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=turismo-oculto
VITE_FIREBASE_STORAGE_BUCKET=turismo-oculto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=PEGA_AQUI
VITE_FIREBASE_APP_ID=PEGA_AQUI

# Emails que pueden entrar en /team (separados por coma)
VITE_ADMIN_EMAILS=josvierrod@exploreapphq.com

# --- EMAIL waitlist (Netlify Function — obligatorio para correo de bienvenida) ---
# Resend.com → API Keys → crea key → SMTP
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_PEGA_TU_API_KEY_DE_RESEND
SMTP_FROM=Explore <onboarding@resend.dev>

# URL pública del sitio (tu dominio Netlify o custom)
SITE_URL=https://sunny-dolphin-b73804.netlify.app

# Enlaces en emails (opcional, ya tienen default)
APP_STORE_URL=https://apps.apple.com/do/app/explore-tourism/id6748882805?l=en-GB
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.explore.miapp&hl=es

# --- Solo si usas API en Railway (opcional) ---
# VITE_API_URL=https://tu-api.up.railway.app
